{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "PoE Inspect",
	"version": "0.0.0-dev",
	"identifier": "com.poe-inspect.app",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"label": "overlay",
				"title": "PoE Inspect",
				"width": 1920,
				"height": 1080,
				"decorations": false,
				"transparent": true,
				"alwaysOnTop": true,
				"skipTaskbar": true,
				"resizable": false,
				"visible": false,
				"focus": false,
				"shadow": false
			},
			{
				"label": "settings",
				"title": "PoE Inspect — Settings",
				"url": "index.html",
				"width": 720,
				"height": 520,
				"minWidth": 600,
				"minHeight": 400,
				"decorations": true,
				"resizable": true,
				"visible": false,
				"center": true,
				"dragDropEnabled": false
			},
			{
				"label": "browser",
				"title": "PoE Inspect — Browser",
				"url": "index.html",
				"width": 1100,
				"height": 750,
				"minWidth": 800,
				"minHeight": 500,
				"decorations": true,
				"resizable": true,
				"visible": false,
				"center": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"createUpdaterArtifacts": true,
		"resources": {
			"../../crates/poe-data/data/*": "data/"
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk0NDY2ODkwM0FERDRGRDIKUldUU1Q5MDZrR2hHbEVtTmU5Ti9ubnJtRVloSlVyVk9zcUxXSWxhOXRCaTdBZ1NRaDhreDhodzcK",
			"endpoints": [
				"https://github.com/timeloop-vault/poe-inspect/releases/latest/download/latest.json"
			]
		}
	}
}
